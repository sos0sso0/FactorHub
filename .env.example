# FactorFlow 环境变量配置示例
# 复制此文件为 .env 并根据需要修改配置

# API 配置
API_HOST=0.0.0.0
API_PORT=8000

# CORS 配置 (生产环境应设置具体域名)
# CORS_ORIGINS=["http://localhost:8501","http://localhost:3000"]

# 数据库配置
# DATABASE_URL=sqlite:///./data/factor_flow.db

# Streamlit 配置
STREAMLIT_HOST=localhost
STREAMLIT_PORT=8501

# akshare 缓存配置
# AKSHARE_CACHE_ENABLED=true

# 日志配置
LOG_LEVEL=INFO

# 分析配置
# DEFAULT_ANALYSIS_WINDOW=252
# DEFAULT_TEST_SIZE=0.2
# SHAP_ENABLED=true
